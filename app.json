{
  "expo": {
    "name": "PlanCall",
    "slug": "plan-call",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/plancall-logo.png",
    "scheme": "plancall",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "LSApplicationQueriesSchemes": ["kakaomap"]
      }
    },
    "android": {
      "package": "com.j_company.plancall",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/plancall-logo.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/plancall-logo.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "@react-native-community/datetimepicker",
      "expo-font",
      "expo-notifications",
      "./plugins/withKakaoMapQueries"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "f7c6b962-894b-4b77-8eef-1e7738b41d59"
      }
    }
  }
}
